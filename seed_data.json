{
  "model": "gameplay.quest",
  "pk": 3,
  "fields": {
    "name": "Harvest the fields",
    "description": "The fields are ripe with crops, and it's time to gather the harvest. The work is tough, but the rewards are plenty. Whether you're gathering wheat, barley, or vegetables, your contribution will ensure the village has enough food for the coming months.",
    "intro_text": "As the sun rises over the fields, you can see the golden crops swaying gently in the breeze. The harvest is upon us, and the work is as important as it is demanding. The grains, fruits, and vegetables are ready for picking, and it's your task to gather as much as you can. If the harvest is successful, the village will thrive throughout the winter. But be warned, this is not an easy task. It will take time, but the rewards will be worth it.",
    "outro_text": "After hours in the fields, you finally stand tall with baskets full of fresh produce. The grains have been harvested, and the village now has food to sustain itself. There's a deep sense of satisfaction in knowing your work will feed your people. With the harvest complete, it's time to rest until the next task is upon us.",
    "duration_choices": [
      300,
      600,
      900,
      1200,
      1500,
      1800
    ],
    "created_at": "2025-02-02T02:13:40.025Z",
